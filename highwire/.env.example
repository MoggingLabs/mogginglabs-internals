# ─────────────────────────────────────────────────────────────────────
#  Highwire — local configuration
#  Copy this file to `.env` and fill in YOUR values.
#  `.env` is gitignored and must NEVER be committed. Placeholders only here.
# ─────────────────────────────────────────────────────────────────────

# The GoHighLevel Firebase refresh token grabbed from your logged-in session.
# See docs/USAGE.md for how to capture it. Store it here and nowhere else.
GHL_REFRESH_TOKEN=paste-your-refresh-token-here

# The sub-account / location you want Highwire to operate on.
# Found in the GHL URL:  app.<yourdomain>.com/location/<THIS-PART>/...
GHL_LOCATION_ID=your-location-id-here

# (Optional) Public private-integration token, if a given endpoint needs it.
# Starts with "pit-". Leave blank if unused.
GHL_PRIVATE_INTEGRATION_TOKEN=

# ── Pacing / safety knobs (safe defaults; tune down, rarely up) ──────
# Minimum + maximum think-time between actions, in seconds (randomized).
HIGHWIRE_MIN_DELAY_S=1.5
HIGHWIRE_MAX_DELAY_S=6.0
# Hard ceilings so a runaway job can't hammer the API.
HIGHWIRE_MAX_OPS_PER_HOUR=300
HIGHWIRE_MAX_WRITES_PER_HOUR=60
# Set to 1 to preview writes without sending them.
HIGHWIRE_DRY_RUN=0
